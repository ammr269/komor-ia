// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin
  user
  developer
  journaliste
  translator // Nouveau rôle pour les traducteurs
}

enum ModelStatus {
  development
  beta
  production
  deprecated
}

enum ProfilStatus {
  private
  public
}

enum ArticleStatus {
  draft // Brouillon
  pending // En attente de traduction
  in_progress // Traduction en cours
  completed // Traduction terminée
  verified // Traduction vérifiée
}

enum ArticleLanguage {
  fr // Français
  en // Anglais
  ar // Arabe
  sw // Swahili
  zdj // Comorien (Ngazidja)
  other
}

enum ArticleCategory {
  news // Actualités
  literature // Littérature
  education // Éducation
  science // Science
  culture // Culture
  religion // Religion
  history // Histoire
  other
}

// ============================================
// MODÈLES PRINCIPAUX
// ============================================

model User {
  id            Int       @id @default(autoincrement())
  name          String?
  email         String    @unique
  hashPassword  String?   @map("hash_password")
  image         String?
  role          UserRole  @default(user)
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  profil           Profil?
  apiKeys          ApiKey[]
  usageLogs        UsageLog[]
  accounts         Account[]
  sessions         Session[]
  translations     Translation[] // Traductions faites par l'utilisateur
  translationEdits TranslationEdit[] // Historique des modifications
  userSettings     UserSettings?

  @@index([email])
  @@map("users")
}

model Profil {
  id        Int          @id @default(autoincrement())
  bio       String?      @db.Text
  location  String?
  website   String?
  phone     String?
  status    ProfilStatus @default(private)
  userId    Int          @unique @map("user_id")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profils")
}

model Modele {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  slug        String      @unique
  description String      @db.Text
  domaine     String
  version     String      @default("1.0.0")
  status      ModelStatus @default(development)
  endpoint    String?
  icon        String?     @default("Brain")
  color       String?     @default("blue")
  isPublic    Boolean     @default(true) @map("is_public")
  features    Json?
  pricing     Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  apiKeys   ApiKey[]
  usageLogs UsageLog[]

  @@index([slug])
  @@index([status])
  @@map("modeles")
}

// ============================================
// SYSTÈME D'ARTICLES ET TRADUCTIONS
// ============================================

model Article {
  id             Int             @id @default(autoincrement())
  title          String          @db.VarChar(500)
  slug           String          @unique
  originalText   String          @map("original_text") @db.LongText
  originalLang   ArticleLanguage @default(fr) @map("original_lang")
  targetLang     ArticleLanguage @default(zdj) @map("target_lang")
  category       ArticleCategory @default(other)
  status         ArticleStatus   @default(pending)
  difficulty     Int             @default(1) // 1-5: facilité de traduction
  estimatedWords Int             @default(0) @map("estimated_words")
  source         String?         @db.VarChar(500) // Source de l'article
  author         String?         @db.VarChar(255)
  publishedDate  DateTime?       @map("published_date")
  tags           Json? // Tags pour filtrage
  metadata       Json? // Métadonnées additionnelles
  priority       Int             @default(0) // 0-10: priorité de traduction
  isPublic       Boolean         @default(true) @map("is_public")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  translations     Translation[]
  translationEdits TranslationEdit[]

  @@index([slug])
  @@index([status])
  @@index([category])
  @@index([originalLang, targetLang])
  @@map("articles")
}

model Translation {
  id               Int           @id @default(autoincrement())
  articleId        Int           @map("article_id")
  userId           Int           @map("user_id")
  translatedText   String        @map("translated_text") @db.LongText
  progress         Int           @default(0) // Pourcentage de complétion (0-100)
  status           ArticleStatus @default(in_progress)
  quality          Int? // 1-5: qualité de la traduction (évaluation)
  timeSpent        Int           @default(0) @map("time_spent") // Temps en secondes
  isActive         Boolean       @default(true) @map("is_active") // Si c'est la traduction active
  verifiedBy       Int?          @map("verified_by") // ID de l'utilisateur qui a vérifié
  verifiedAt       DateTime?     @map("verified_at")
  notes            String?       @db.Text // Notes du traducteur
  lastEditPosition Int           @default(0) @map("last_edit_position") // Position du dernier edit
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Relations
  article Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  edits   TranslationEdit[]

  @@unique([articleId, userId, isActive]) // Un seul brouillon actif par user/article
  @@index([articleId])
  @@index([userId])
  @@index([status])
  @@map("translations")
}

model TranslationEdit {
  id            Int      @id @default(autoincrement())
  translationId Int      @map("translation_id")
  articleId     Int      @map("article_id")
  userId        Int      @map("user_id")
  editedText    String   @map("edited_text") @db.LongText // État du texte à ce moment
  progress      Int      @default(0) // Progrès à ce moment
  sessionStart  DateTime @map("session_start")
  sessionEnd    DateTime @map("session_end")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  translation Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
  article     Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([translationId])
  @@index([userId])
  @@map("translation_edits")
}

// ============================================
// SYSTÈME API
// ============================================

model ApiKey {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  name      String
  userId    Int       @map("user_id")
  modeleId  Int?      @map("modele_id")
  isActive  Boolean   @default(true) @map("is_active")
  rateLimit Int       @default(1000) @map("rate_limit")
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  modele    Modele?    @relation(fields: [modeleId], references: [id])
  usageLogs UsageLog[]

  @@index([userId])
  @@index([modeleId])
  @@index([key])
  @@map("api_keys")
}

model UsageLog {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  apiKeyId     Int      @map("api_key_id")
  modeleId     Int      @map("modele_id")
  endpoint     String
  method       String   @default("POST")
  statusCode   Int      @map("status_code")
  responseTime Int      @map("response_time")
  tokens       Int      @default(0)
  cost         Float    @default(0.0)
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  modele Modele @relation(fields: [modeleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([apiKeyId])
  @@index([modeleId])
  @@index([createdAt])
  @@map("usage_logs")
}

// ============================================
// NEXTAUTH
// ============================================

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int     @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id         Int      @id @default(autoincrement())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// INFO ENTREPRISE
// ============================================

model KMIA {
  id          Int      @id @default(autoincrement())
  name        String   @default("Komor-IA")
  slogan      String?
  description String?  @db.Text
  logo        String?
  email       String?
  phone       String?
  address     String?
  website     String?
  social      Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("kmia")
}

model UserSettings {
  id     Int @id @default(autoincrement())
  userId Int @unique @map("user_id")

  // Préférences d'affichage
  theme    String @default("light") // light, dark, auto
  language String @default("fr") // fr, en, ar, sw, zdj
  timezone String @default("Africa/Moroni")

  // Notifications
  emailNotifications Boolean @default(true) @map("email_notifications")
  usageAlerts        Boolean @default(true) @map("usage_alerts")
  monthlyReports     Boolean @default(true) @map("monthly_reports")
  securityAlerts     Boolean @default(true) @map("security_alerts")

  // Limites et quotas
  dailyRequestLimit     Int?   @map("daily_request_limit")
  monthlyBudgetLimit    Float? @map("monthly_budget_limit")
  quotaWarningThreshold Int    @default(80) @map("quota_warning_threshold") // %

  // API Defaults
  defaultModel     String? @map("default_model")
  defaultMaxTokens Int     @default(1000) @map("default_max_tokens")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relation
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_settings")
}

